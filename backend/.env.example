APP_NAME=Dream Home Design API
APP_VERSION=1.0.0
API_PREFIX=/api
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dream_home_design

# Email notifications via Resend (https://resend.com).
# If empty, messages print in backend logs.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Interior Design <noreply@yourdomain.com>

# Optional SMTP (useful if you prefer SMTP over API; Resend supports SMTP)
# Host: smtp.resend.com  Port: 465 (SSL) or 587 (STARTTLS)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=Interior Design <noreply@yourdomain.com>
# Optional SMS OTP notifications. If empty, OTP messages print in backend logs.
# SMS_PROVIDER supports "fast2sms" or "twilio".
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional WhatsApp Cloud API. If empty, WhatsApp messages print in backend logs.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CONTACT_NUMBER=

# Meta Lead Ads webhook.
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
