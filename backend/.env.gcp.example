# GCP Environment Variables Template
# Copy this file to .env.gcp and fill in the actual values
# NEVER commit this file to version control

# ─────────────────────────────────────────────────────
# GCP Project Settings
# ─────────────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id
REGION=us-central1

# ─────────────────────────────────────────────────────
# Cloud SQL Configuration
# ─────────────────────────────────────────────────────
DB_PASSWORD=your-secure-database-password
CLOUD_SQL_CONNECTION=your-project:us-central1:interior-db
DATABASE_URL=postgresql://admin:DB_PASSWORD@/interior_db?host=/cloudsql/CLOUD_SQL_CONNECTION

# ─────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────
PORT=8080
SECRET_KEY=your-generated-secret-key-use-openssl-rand-hex-32
RUN_MIGRATIONS=true
PYTHONUNBUFFERED=1

# ─────────────────────────────────────────────────────
# CORS & Frontend Configuration
# ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# ─────────────────────────────────────────────────────
# Email Configuration (SMTP)
# ─────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
MAIL_FROM=noreply@your-company.com

# ─────────────────────────────────────────────────────
# Email Configuration (Resend - Alternative)
# ─────────────────────────────────────────────────────
# Uncomment to use Resend instead of SMTP
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM_EMAIL=noreply@your-company.com

# ─────────────────────────────────────────────────────
# Cloud Build Settings
# ─────────────────────────────────────────────────────
SERVICE_NAME=interior-backend
ARTIFACT_REGISTRY_REPO=interior-backend

# ─────────────────────────────────────────────────────
# VPC & Network Configuration
# ─────────────────────────────────────────────────────
VPC_CONNECTOR=interior-vpc-connector
