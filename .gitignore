#!/bin/bash

# .gitignore - Production Deployment Settings
# This ensures sensitive files are not committed

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pyc
.pytest_cache/

# Node / Frontend
node_modules/
dist/
build/
*.tsbuildinfo
.next/
.nuxt/
out/

# Dependency lock files (optional - include these for reproducible builds)
# npm-shrinkwrap.json
# package-lock.json kept for reproducibility
# yarn.lock kept for reproducibility
# pnpm-lock.yaml kept for reproducibility

# Environment Variables (IMPORTANT - never commit secrets)
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.test.local

# IDE & Editor
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
.vim/
.emacs.desktop

# OS
.DS_Store
Thumbs.db
.directory
.AppleDouble
.LSOverride
._*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Testing
.coverage
.pytest_cache/
.nyc_output/
htmlcov/

# Uploads (use cloud storage in production)
uploads/
temp/
tmp/

# Vercel Specific
.vercel/
vercel.json.local

# Database dumps (don't commit)
*.sql
*.dump
*.backup

# Docker (if using)
docker-compose.override.yml

# Build outputs (keep in gitignore)
*.o
*.a
*.so
*.dylib

# Keep these for production:
# - requirements.txt
# - package.json
# - package-lock.json (reproducible builds)
# - vercel.json (deployment config)
# - .env.example (template only)
